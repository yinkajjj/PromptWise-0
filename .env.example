# App branding
VITE_APP_TITLE=Promptwise
VITE_APP_LOGO=https://placehold.co/128x128/E1E7EF/1F2937?text=App

# OAuth integration (required if login is enabled)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# Optional analytics (Umami)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# AI generation provider (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Background generation job controls
PROMPT_JOB_CHUNK_SIZE=50
PROMPT_JOB_MAX_COUNT=10000
PROMPT_JOB_RETENTION_MS=86400000
PROMPT_JOB_MAX_SAVED=500

# Optional API protection for generation endpoints (/api/prompts/*)
PROMPTWISE_API_KEY=

# Durable queue mode (optional): when REDIS_URL is set, jobs use BullMQ instead of in-memory queue
REDIS_URL=
PROMPT_QUEUE_NAME=promptwise-generation-jobs
PROMPT_QUEUE_CONCURRENCY=2
PROMPT_QUEUE_ATTEMPTS=1

# Durable job/result persistence (optional): when DATABASE_URL is set, jobs and prompts are stored in Postgres
DATABASE_URL=
PG_POOL_MAX=10
